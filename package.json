{
  "name": "webmcp-extension",
  "version": "0.1.0",
  "description": "AI-powered WebMCP tool inference for any web page",
  "license": "MIT",
  "private": true,
  "keywords": [
    "webmcp",
    "chrome-extension",
    "ai-agent",
    "browser-automation",
    "llm",
    "vertex-ai",
    "anthropic"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ColinWhittingham/webmcp-browser-extension"
  },
  "homepage": "https://github.com/ColinWhittingham/webmcp-browser-extension#readme",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "postinstall": "wxt prepare",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/chrome": "^0.0.289",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10",
    "vitest-chrome": "^0.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^25.0.1",
    "@testing-library/react": "^16.0.1",
    "@testing-library/jest-dom": "^6.6.2",
    "wxt": "^0.19.8",
    "@vitejs/plugin-react": "^4.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
